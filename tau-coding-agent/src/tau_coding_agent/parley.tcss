/* Parley stylesheet - clean, minimal, fast */
/* Color palette: Warm grays with soft accent colors for comfortable long sessions */

Screen {
    background: #1e1e2e;  /* Deep blue-gray, easy on eyes */
}

/* === Sidebar === */
#sidebar {
    width: 30;
    background: #181825;  /* Slightly darker than main */
    border-right: solid #45475a;  /* Subtle gray border */
}

.sidebar-title {
    text-align: center;
    text-style: bold;
    color: #cdd6f4;  /* Soft lavender for titles */
    padding: 1;
    background: #11111b;
}

#new-chat-button {
    margin: 1;
    width: 100%;
    background: #313244;
    color: #cdd6f4;
    border: solid #45475a;
}

#new-chat-button:hover {
    background: #45475a;
}

.chat-group-header {
    margin-top: 1;
    padding: 0 1;
    color: #6c7086;  /* Muted for group headers */
    text-style: italic;
}

.chat-list-item {
    padding: 0 2;
    margin: 0;
    color: #bac2de;
}

.chat-list-item:hover {
    background: #313244;
    color: #cdd6f4;
}

.chat-list-empty {
    padding: 1;
    color: #6c7086;
    text-style: italic;
}

#chat-list {
    height: 1fr;
    padding: 1;
}

#chat-list-content {
    padding: 0 1;
}

/* === Chat Display === */
#chat-display {
    height: 1fr;
    padding: 1 2;
    background: #1e1e2e;
}

/* === Message Styling === */
/* ONE universal widget (MessageBox) renders every message. The role selects a
   border color + label on the BOX ITSELF, so an assistant's reasoning + answer
   + tool boxes all sit inside one titled border (one completion = one box). */
.chat-message {
    margin: 1 0;
    height: auto;
    padding: 1;
    border: solid #45475a;  /* default; per-role rules below recolor */
}

/* The lazy reasoning / tools slots collapse to nothing when empty, so a plain
   user/system message looks exactly like a single text box. */
.message-reasoning, .message-tools {
    height: auto;
}

.message-content {
    color: #cdd6f4;
}

/* Pending placeholder — muted, until it resolves into a real role */
.box-pending {
    border: solid #6c7086;  /* Muted gray */
    color: #6c7086;
}

.box-user { border: solid #89dceb; }       /* calm cyan */
.box-assistant { border: solid #f9e2af; }  /* warm amber */
.box-system { border: solid #cba6f7; }     /* subtle purple */
.box-toolCall { border: solid #fab387; }   /* orange (legacy standalone tool box) */
.box-toolResult { border: solid #a6e3a1; margin: 1 0 1 2; }  /* green, indented */
.box-error { border: solid #f38ba8; }      /* red */
.box-blocked { border: solid #f9e2af; }    /* amber — an extension veto (S50), not a tool failure */

/* === Reasoning / thinking regions (collapsible, dim+italic like pi) === */
.reasoning-region {
    margin: 0 0 1 0;
}

.reasoning-region > CollapsibleTitle {
    color: #9399b2;  /* muted gray */
    text-style: italic;
}

.reasoning-region Markdown {
    color: #9399b2;
    text-style: italic;
}

/* === Tool call + result boxes (one collapsible per call) === */
.tool-box {
    margin: 0 0 1 0;
}

.tool-box > CollapsibleTitle {
    color: #fab387;  /* soft orange, matches the old tool-call color */
}

.tool-box.box-error > CollapsibleTitle {
    color: #f38ba8;  /* soft red on error */
}

.tool-box.box-blocked > CollapsibleTitle {
    color: #f9e2af;  /* amber — a `tool_call` extension veto (S50), read as a policy block */
}

/* === Exchange grouping (one user→answer span; summary line title) === */
.exchange-box {
    margin: 1 0;
}

.exchange-box > CollapsibleTitle {
    color: #cdd6f4;
    text-style: bold;
}

/* === Input Styling === */
#chat-input {
    margin: 0 1 1 1;
    border: solid #45475a;
    height: auto;
    max-height: 10;
    background: #181825;
    color: #cdd6f4;
}

#chat-input:focus {
    border: solid #89dceb;  /* Matches user message color */
    background: #1e1e2e;
}

/* === System Prompt Editor Modal === */
#prompt-editor-dialog {
    width: 80;
    height: 25;
    background: #181825;
    border: thick #45475a;
    padding: 1;
}

#prompt-editor-title {
    text-align: center;
    text-style: bold;
    color: #cba6f7;
    margin-bottom: 1;
}

#prompt-editor-textarea {
    height: 1fr;
    margin-bottom: 1;
    background: #1e1e2e;
    border: solid #45475a;
    color: #cdd6f4;
}

#prompt-editor-textarea:focus {
    border: solid #cba6f7;
}

#prompt-editor-buttons {
    height: auto;
    align: center middle;
}

#prompt-editor-buttons Button {
    margin: 0 1;
    background: #313244;
    border: solid #45475a;
    color: #cdd6f4;
}

#prompt-editor-buttons Button:hover {
    background: #45475a;
}

/* === Session Tree Browser Modal === */
#tree-browser-dialog {
    width: 90;
    height: 30;
    background: #181825;
    border: thick #45475a;
    padding: 1;
}

#tree-browser-title {
    text-align: center;
    text-style: bold;
    color: #cba6f7;
    margin-bottom: 1;
}

#tree-browser-tree {
    height: 1fr;
    background: #1e1e2e;
    border: solid #45475a;
    color: #cdd6f4;
}

#tree-browser-tree:focus {
    border: solid #cba6f7;
}

#tree-browser-help {
    text-align: center;
    color: #6c7086;
    margin-top: 1;
}

/* === Tree three-mode chooser Modal === */
#tree-mode-dialog {
    width: 60;
    height: auto;
    background: #181825;
    border: thick #45475a;
    padding: 1;
}

#tree-mode-title {
    text-align: center;
    text-style: bold;
    color: #cba6f7;
    margin-bottom: 1;
}

#tree-mode-buttons {
    height: auto;
    align: center middle;
}

#tree-mode-buttons Button {
    width: 100%;
    margin-bottom: 1;
    background: #313244;
    border: solid #45475a;
    color: #cdd6f4;
}

#tree-mode-buttons Button:hover {
    background: #45475a;
}

/* === Extension dialogs (confirm / select / input) — E7 §3 / S47 === */
#ext-confirm-dialog, #ext-select-dialog, #ext-input-dialog {
    width: 70;
    height: auto;
    background: #181825;
    border: thick #45475a;
    padding: 1;
}

#ext-select-dialog {
    height: 30;
}

#ext-confirm-title, #ext-select-title, #ext-input-title {
    text-align: center;
    text-style: bold;
    color: #cba6f7;
    margin-bottom: 1;
}

#ext-confirm-message {
    margin-bottom: 1;
    color: #cdd6f4;
}

#ext-confirm-buttons, #ext-input-buttons {
    height: auto;
    align: center middle;
}

#ext-confirm-buttons Button, #ext-input-buttons Button {
    margin: 0 1;
    background: #313244;
    border: solid #45475a;
    color: #cdd6f4;
}

#ext-confirm-buttons Button:hover, #ext-input-buttons Button:hover {
    background: #45475a;
}

#ext-select-list {
    height: 1fr;
    background: #1e1e2e;
    border: solid #45475a;
    color: #cdd6f4;
}

#ext-select-list:focus {
    border: solid #cba6f7;
}

#ext-select-help {
    text-align: center;
    color: #6c7086;
    margin-top: 1;
}

#ext-input-field {
    margin-bottom: 1;
    background: #1e1e2e;
    border: solid #45475a;
    color: #cdd6f4;
}

#ext-input-field:focus {
    border: solid #cba6f7;
}

/* === Extension form (declarative fields) — E10 §6 / S66 === */
#ext-form-dialog {
    width: 70;
    height: auto;
    max-height: 90%;
    background: #181825;
    border: thick #45475a;
    padding: 1;
}

#ext-form-title {
    text-align: center;
    text-style: bold;
    color: #cba6f7;
    margin-bottom: 1;
}

#ext-form-fields {
    height: auto;
    max-height: 24;
}

.ext-form-label {
    color: #a6adc8;
    margin-top: 1;
}

.ext-form-input {
    background: #1e1e2e;
    border: solid #45475a;
    color: #cdd6f4;
}

.ext-form-input:focus {
    border: solid #cba6f7;
}

#ext-form-help {
    text-align: center;
    color: #6c7086;
    margin-top: 1;
}

#ext-form-buttons {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#ext-form-buttons Button {
    margin: 0 1;
    background: #313244;
    border: solid #45475a;
    color: #cdd6f4;
}

#ext-form-buttons Button:hover {
    background: #45475a;
}

/* === Extension status strip (E10 §6 / S67) === */
/* One-line keyed status slots from ctx.ui.set_status(), just above the Footer.
   Hidden (display:none, set in code) until an extension writes a slot. */
#ext-status-bar {
    height: 1;
    width: 100%;
    padding: 0 1;
    background: #181825;
    color: #a6adc8;
    text-style: dim;
}

/* === Code blocks in markdown === */
Markdown CodeBlock {
    background: #11111b;
    border: solid #313244;
    color: #a6e3a1;  /* Soft green for code */
}

/* Tool-call / tool-result blocks are rendered by the shared MessageBox widget
   (see the `.box-toolCall` / `.box-toolResult` rules above), not by a separate
   Static widget. */
