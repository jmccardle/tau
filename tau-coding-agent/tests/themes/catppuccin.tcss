/* Minimal Catppuccin-inspired Theme for τ-coding-agent TUI */

/* Dark theme using Textual's built-in color aliases */
Screen {
    background: $boost;
    color: $text;
}

/* Header styling */
Header {
    background: $primary;
    color: $text;
}

/* Footer styling */
Footer {
    background: $surface;
    color: $text;
}

/* Chat display area */
ChatDisplay {
    background: $surface;
}

#chat-log {
    background: $surface;
    color: $text;
}

/* Input bar */
#input-bar {
    height: 5;
    background: $surface;
}

InputBar {
    background: $surface;
    color: $text;
}

Input {
    background: $boost;
    color: $text;
    width: 100%;
}

/* Tool call widget */
ToolCallWidget {
    background: $surface;
    margin: 1 1;
    padding: 1 2;
}

/* Tool result widget */
ToolResultWidget {
    background: $surface;
    margin: 1 1;
    padding: 1 2;
}
